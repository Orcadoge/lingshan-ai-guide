generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum SourceType {
  official
  audited
  media
  encyclopedia
}

model SourceRecord {
  id          String      @id
  sourceType  SourceType
  title       String
  url         String
  publisher   String
  publishedAt DateTime?
  fetchedAt   DateTime
  pois        Poi[]
  foodVenues  FoodVenue[]
  dishes      Dish[]
}

model Poi {
  id                   String       @id
  name                 String
  slug                 String       @unique
  district             String
  level                String?
  lat                  Float
  lng                  Float
  tags                 String[]
  themeSlugs           String[]
  intro                String
  culturalStory        String?
  recommendStayMinutes Int
  openingHours         String?
  ticketPriceRange     String?
  suitableCrowd        String[]
  transportTips        String?
  nearbyFoodIds        String[]
  sourceId             String
  freshnessDate        DateTime
  reviewStatus         ReviewStatus
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  source               SourceRecord @relation(fields: [sourceId], references: [id])
}

model FoodVenue {
  id              String       @id
  name            String
  slug            String       @unique
  district        String
  lat             Float
  lng             Float
  avgPrice        Int
  spicyLevel      String
  tags            String[]
  themeSlugs      String[]
  intro           String
  openingHours    String?
  signatureDishes String[]
  suitableCrowd   String[]
  cultureStory    String?
  bestTimeToEat   String?
  sourceId        String
  freshnessDate   DateTime
  reviewStatus    ReviewStatus
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  source          SourceRecord @relation(fields: [sourceId], references: [id])
}

model Dish {
  id             String       @id
  name           String
  slug           String       @unique
  district       String
  tags           String[]
  themeSlugs     String[]
  intro          String
  flavor         String
  cultureTags    String[]
  relatedVenueIds String[]
  sourceId       String
  freshnessDate  DateTime
  reviewStatus   ReviewStatus
  bestTimeToEat  String?
  suitableCrowd  String[]
  spicyLevel     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  source         SourceRecord @relation(fields: [sourceId], references: [id])
}

model Theme {
  id             String   @id
  name           String
  slug           String   @unique
  intro          String
  seoText        String
  heroImage      String
  featureBullets String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PlanSession {
  id           String   @id
  shareId      String   @unique
  inputPayload Json
  parsedIntent Json
  resultPayload Json
  modelMeta    Json
  createdAt    DateTime @default(now())
  feedback     UserFeedback[]
}

model UserFeedback {
  id            String      @id
  planSessionId String
  rating        Int
  useful        Boolean
  comment       String?
  createdAt     DateTime    @default(now())
  planSession   PlanSession  @relation(fields: [planSessionId], references: [id])
}

model PromptConfig {
  id           String   @id
  name         String
  version      String
  description  String
  systemPrompt String
  isPublished  Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

// === 新增：数字人/情感分析/会话统计 ===

model VisitorSession {
  id            String   @id @default(cuid())
  source        String   // WEB / APP / TERMINAL
  deviceInfo    String?
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  hasVoice      Boolean  @default(false)
  hasDigitalHuman Boolean @default(false)
  messageCount  Int      @default(0)
  conversionStatus String @default("active") // active / completed / abandoned
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  emotions      VisitorEmotion[]
  analytics     SessionAnalytics?
}

model VisitorEmotion {
  id            String   @id @default(cuid())
  sessionId     String
  session       VisitorSession @relation(fields: [sessionId], references: [id])
  source        EmotionSource @default(TEXT)
  textContent   String?
  textSentiment Json?    // { emotion, confidence, details, keywords }
  voiceFeatures Json?    // { pitch, energy, speed } - 预留
  faceFeatures  Json?    // { expression, intensity } - 预留
  poiId         String?
  createdAt     DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

enum EmotionSource {
  TEXT
  VOICE
  FACE
  FUSED
}

model SessionAnalytics {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  session        VisitorSession @relation(fields: [sessionId], references: [id])
  totalEmotions  Int      @default(0)
  positiveCount  Int      @default(0)
  neutralCount   Int      @default(0)
  negativeCount  Int      @default(0)
  topEmotion     String   @default("neutral") // positive / neutral / negative
  satisfactionScore Float? // 0-100
  updatedAt      DateTime @updatedAt
}

model DigitalHumanConfig {
  id             String   @id @default(cuid())
  name           String
  provider       String   @default("did") // did / volcengine / local
  avatarImageUrl String?
  sourceUrl      String?  // D-ID source image URL
  voiceType      String?  // TTS voice ID
  modelId        String?  // 3D model reference
  isDefault      Boolean  @default(false)
  configJson     String?  // provider-specific config
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isDefault])
}

model EmotionReport {
  id            String   @id @default(cuid())
  reportDate    DateTime @default(now())
  period        String   // daily / weekly / monthly
  totalVisitors Int
  avgSatisfaction Float?
  emotionDistribution Json // { positive: 0.5, neutral: 0.3, negative: 0.2 }
  hotTopics     Json?    // ["祈福", "素斋", "梵宫"]
  suggestions   String?
  createdAt     DateTime @default(now())
}
